# App
APP_NAME=Fix My Kit API
API_HOST=0.0.0.0
API_PORT=8000
API_DOCS_ENABLED=true
LOG_LEVEL=INFO
FRONTEND_PORT=5173
VITE_PROXY_TARGET=http://backend:8000
PUBLIC_FRONTEND_BASE_URL=https://fixmykit.local
JWT_SECRET_KEY=secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin_password

#win+r -> powershell -> python -c "import secrets; print(secrets.token_urlsafe(32))" -> copy and paste into JWT_SECRET_KEY and paste into .env/.env.example
# PostgreSQL 
POSTGRES_DB=fixmykit
POSTGRES_USER=fixmykit
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Yandex Tracker
TRACKER_BASE_URL=https://api.tracker.yandex.net/v3
TRACKER_TOKEN=
TRACKER_ORG_ID=
TRACKER_QUEUE=
TRACKER_TIMEOUT_SECONDS=15

# Триггер Yandex Tracker
# POST …/api/webhooks/yandex-tracker
# заголовок X-Tracker-Webhook-Secret
TRACKER_WEBHOOK_SECRET=
TRACKER_WEBHOOK_ACTOR_LOGIN=tracker_webhook

# Вложения заявок (временно на диске до Трекера)
UPLOAD_DIR=data/uploads
ATTACHMENT_MAX_BYTES=1073741824
ATTACHMENT_MAX_PER_REQUEST=10
ATTACHMENT_ORPHAN_MAX_AGE_DAYS=30
