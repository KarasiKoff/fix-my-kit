#win+r -> powershell -> python -c "import secrets; print(secrets.token_urlsafe(32))"
# App
APP_NAME=Fix My Kit API
LOG_LEVEL=warning
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_LOGIN=
ADMIN_PASSWORD=

# CORS: origin фронта
# Должен совпадать с публичным URL приложения, например https://app.fixmykit.example.com
CORS_ORIGINS=https://app.fixmykit.example.com

# Базовый URL фронта для ссылок из бэка QR и т.п.
PUBLIC_FRONTEND_BASE_URL=https://app.fixmykit.example.com

# PostgreSQL 
POSTGRES_DB=fixmykit
POSTGRES_USER=fixmykit
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Yandex Tracker
TRACKER_BASE_URL=https://api.tracker.yandex.net/v3
TRACKER_TOKEN=
TRACKER_ORG_ID=
TRACKER_QUEUE=
TRACKER_TIMEOUT_SECONDS=15

# Полный URL API
VITE_API_BASE_URL=https://api.fixmykit.example.com